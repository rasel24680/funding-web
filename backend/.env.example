# ========================================
# LENDER API CONFIGURATIONS
# ========================================

# Bizcap API Configuration (docs.bizcap.com.au)
BIZCAP_ENABLED=true
BIZCAP_API_KEY=your-bizcap-api-key
BIZCAP_PARTNER_ID=your-bizcap-partner-id
BIZCAP_PARTNER_CONTACT_ID=your-bizcap-partner-contact-id

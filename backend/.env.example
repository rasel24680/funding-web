# MyPulse Lending API Configuration (mypulse.io/docs/api/lending-api)
MYPULSE_ENABLED=true
MYPULSE_ENVIRONMENT=sandbox  # sandbox or production
MYPULSE_CLIENT_ID=your-mypulse-client-id
MYPULSE_CLIENT_SECRET=your-mypulse-client-secret
MYPULSE_SCOPE=api://your-scope/.default
MYPULSE_SUBSCRIPTION_KEY=your-subscription-key
MYPULSE_DISPLAY_NAME=SME Finance Partner  # User-facing name (hides API provider)

# Companies House API (optional - for company name search)
# Register free at https://developer.company-information.service.gov.uk/
